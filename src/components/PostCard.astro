---
import {
  type PostSummary,
  typeLabel,
  typeBadgeClasses,
} from "../lib/posts.ts";
import { verdictFor, verdictClasses } from "../lib/rating.ts";

interface Props {
  post: PostSummary;
}

const { post } = Astro.props;

const date = post.publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const verdict = post.overall !== undefined ? verdictFor(post.overall) : null;
const colors = verdict ? verdictClasses(verdict.tone) : null;
---

<a
  href={post.href}
  class="post-card group flex flex-col gap-3 rounded-2xl border-2 border-ink/10 bg-cream p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-crimson hover:shadow-md md:flex-row md:gap-5 md:p-5"
  data-slug={post.slug}
  data-page-type={post.pageType}
>
  {
    post.posterUrl ? (
      <img
        src={post.posterUrl}
        alt=""
        loading="lazy"
        class="aspect-[2/3] w-28 shrink-0 rounded-lg object-cover ring-1 ring-ink/10 md:w-32"
      />
    ) : (
      <div class="flex aspect-[2/3] w-28 shrink-0 items-center justify-center rounded-lg bg-cream-dark text-3xl ring-1 ring-ink/10 md:w-32">
        {
          post.type === "tier-list"
            ? "🪜"
            : post.type === "top-10"
              ? "🎯"
              : post.type === "hot-take"
                ? "🌶️"
                : post.type === "trivia"
                  ? "🎓"
                  : "🎬"
        }
      </div>
    )
  }

  <div class="flex flex-1 flex-col">
    <div class="mb-1 flex items-center gap-2 text-xs uppercase tracking-widest text-ink-soft">
      <span class:list={["rounded px-2 py-0.5 font-semibold", typeBadgeClasses(post.type)]}>
        {typeLabel(post.type)}
      </span>
      <span>{date}</span>
      {post.tierCount !== undefined && post.tierCount > 0 && (
        <span class="text-ink-soft">· {post.tierCount} tiers</span>
      )}
      {post.itemCount !== undefined && post.itemCount > 0 && (
        <span class="text-ink-soft">· {post.itemCount} picks</span>
      )}
    </div>
    <h3 class="font-display text-xl font-extrabold leading-tight md:text-2xl">
      {post.title}
    </h3>
    {post.genres && post.genres.length > 0 && (
      <div class="mt-1.5 flex flex-wrap gap-1">
        {post.genres.map((g) => (
          <span
            data-genre-href={`/genre/${g.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}
            class="genre-pill cursor-pointer rounded-full bg-popcorn/20 px-2 py-0.5 text-xs font-medium text-ink-soft hover:bg-popcorn/40 hover:text-ink"
          >
            {g}
          </span>
        ))}
      </div>
    )}
    {post.excerpt && <p class="mt-2 text-[0.95rem] text-ink-soft">{post.excerpt}</p>}

    {
      verdict && colors && post.overall !== undefined && (
        <div class="mt-auto pt-3">
          <span
            class:list={[
              "inline-flex items-center gap-2 rounded-full px-3 py-1 text-sm font-bold ring-2",
              colors.bg,
              colors.text,
              colors.ring,
            ]}
          >
            <span class="font-mono tabular-nums">{post.overall}</span>
            <span aria-hidden="true">·</span>
            <span>
              {verdict.emoji} {verdict.label}
            </span>
          </span>
        </div>
      )
    }

    <!-- Engagement counts — populated client-side -->
    <div class="card-engagement mt-2 flex flex-wrap items-center gap-2 text-xs text-ink-soft/60 empty:hidden">
    </div>
  </div>
</a>

<script>
  const REACTIONS = [
    { key: "thumbs_up", emoji: "👍" },
    { key: "heart",     emoji: "❤️" },
    { key: "popcorn",   emoji: "🍿" },
    { key: "mind_blown",emoji: "🤯" },
  ];

  document.querySelectorAll<HTMLElement>(".genre-pill").forEach((pill) => {
    pill.addEventListener("click", (e) => {
      e.stopPropagation();
      e.preventDefault();
      const href = pill.dataset.genreHref;
      if (href) window.location.href = href;
    });
  });

  document.querySelectorAll<HTMLElement>(".post-card").forEach((card) => {
    const slug = card.dataset.slug;
    const pageType = card.dataset.pageType;
    const engagementEl = card.querySelector(".card-engagement");
    if (!slug || !pageType || !engagementEl) return;

    Promise.all([
      fetch(`/api/reactions/${slug}?type=${pageType}`).then((r) => r.json()).catch(() => ({})),
      fetch(`/api/comments/${slug}?type=${pageType}`).then((r) => r.json()).catch(() => []),
    ]).then(([reactionCounts, comments]: [Record<string, number>, unknown[]]) => {
      const parts: string[] = [];

      for (const { key, emoji } of REACTIONS) {
        const count = reactionCounts[key] ?? 0;
        if (count > 0) parts.push(`${emoji} ${count}`);
      }

      const commentCount = Array.isArray(comments) ? comments.length : 0;
      if (commentCount > 0) {
        parts.push(`💬 ${commentCount}`);
      }

      if (parts.length > 0) {
        engagementEl.innerHTML = parts
          .map((p) => `<span class="rounded-full bg-cream-dark px-2 py-0.5 font-medium">${p}</span>`)
          .join("");
      }
    });
  });
</script>
