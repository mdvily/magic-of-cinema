---
import {
  computeOverall,
  verdictFor,
  verdictClasses,
  SUBCATEGORIES,
  type RatingScores,
} from "../lib/rating.ts";
import RatingBar from "./RatingBar.astro";

interface Props {
  rating: RatingScores;
  /** Show the full subcategory breakdown? Default true. */
  showBreakdown?: boolean;
  /** Compact mode for review cards in lists */
  compact?: boolean;
}

const { rating, showBreakdown = true, compact = false } = Astro.props;
const overall = computeOverall(rating);
const verdict = verdictFor(overall);
const colors = verdictClasses(verdict.tone);
---

<div
  class:list={[
    "rounded-2xl border-2 border-ink/10 bg-cream shadow-sm",
    compact ? "p-3" : "p-5 md:p-6",
  ]}
>
  <div class="flex items-center gap-4 md:gap-6">
    <div
      class:list={[
        "flex flex-col items-center justify-center rounded-2xl ring-4",
        colors.bg,
        colors.text,
        colors.ring,
        compact ? "h-16 w-16" : "h-24 w-24 md:h-28 md:w-28",
      ]}
    >
      <span
        class:list={[
          "font-display font-extrabold leading-none",
          compact ? "text-2xl" : "text-4xl md:text-5xl",
        ]}>{overall}</span>
      <span class:list={[compact ? "text-[0.65rem]" : "text-xs", "mt-0.5 opacity-80"]}>/ 100</span>
    </div>
    <div class="flex-1">
      <p class:list={[compact ? "text-xs" : "text-sm", "uppercase tracking-widest text-ink-soft"]}>
        MovieMan Verdict
      </p>
      <p class:list={[compact ? "text-xl" : "text-2xl md:text-3xl", "font-display font-extrabold"]}>
        <span class="mr-1">{verdict.emoji}</span>
        {verdict.label}
      </p>
    </div>
  </div>

  {
    showBreakdown && (
      <div class="mt-5 grid gap-3 border-t border-ink/10 pt-5 sm:grid-cols-2">
        {SUBCATEGORIES.map((sub) => (
          <RatingBar
            value={rating[sub.key]}
            label={sub.label}
            emoji={sub.emoji}
          />
        ))}
      </div>
    )
  }
</div>
