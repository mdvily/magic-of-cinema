---
import { computeOverall, verdictFor, verdictClasses } from "../lib/rating.ts";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"reviews">;
}

const { entry } = Astro.props;
const data = entry.data;
const overall = data.rating ? computeOverall(data.rating) : null;
const verdict = overall !== null ? verdictFor(overall) : null;
const colors = verdict ? verdictClasses(verdict.tone) : null;

const href = `/reviews/${entry.id.replace(/\.md$/, "")}`;
const date = data.publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a
  href={href}
  class="group flex flex-col gap-3 rounded-2xl border-2 border-ink/10 bg-cream p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-crimson hover:shadow-md md:flex-row md:gap-5 md:p-5"
>
  {
    data.movie?.posterUrl ? (
      <img
        src={data.movie.posterUrl}
        alt={`${data.movie.title} poster`}
        loading="lazy"
        class="aspect-[2/3] w-28 shrink-0 rounded-lg object-cover ring-1 ring-ink/10 md:w-32"
      />
    ) : (
      <div class="flex aspect-[2/3] w-28 shrink-0 items-center justify-center rounded-lg bg-cream-dark text-3xl ring-1 ring-ink/10 md:w-32">
        🎬
      </div>
    )
  }

  <div class="flex flex-1 flex-col">
    <div class="mb-1 flex items-center gap-2 text-xs uppercase tracking-widest text-ink-soft">
      <span class="rounded bg-popcorn/40 px-2 py-0.5 font-semibold text-ink">{data.category}</span>
      <span>{date}</span>
    </div>
    <h3 class="font-display text-xl font-extrabold leading-tight md:text-2xl">
      {data.title}
    </h3>
    {
      data.movie && (
        <p class="mt-0.5 text-sm text-ink-soft">
          {data.movie.title}
          {data.movie.year && <span> · {data.movie.year}</span>}
          {data.movie.director && <span> · dir. {data.movie.director}</span>}
        </p>
      )
    }
    {data.excerpt && <p class="mt-2 text-[0.95rem] text-ink-soft">{data.excerpt}</p>}

    {
      verdict && colors && overall !== null && (
        <div class="mt-auto pt-3">
          <span
            class:list={[
              "inline-flex items-center gap-2 rounded-full px-3 py-1 text-sm font-bold ring-2",
              colors.bg,
              colors.text,
              colors.ring,
            ]}
          >
            <span class="font-mono tabular-nums">{overall}</span>
            <span aria-hidden="true">·</span>
            <span>
              {verdict.emoji} {verdict.label}
            </span>
          </span>
        </div>
      )
    }
  </div>
</a>
