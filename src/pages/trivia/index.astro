---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import GenreFilter from "../../components/GenreFilter.astro";
import { getTrivia, triviaToSummary } from "../../lib/posts.ts";

const items = await getTrivia();
---

<BaseLayout title="Trivia" description="Fun facts and deep cuts from the world of cinema.">
  <GenreFilter />
  <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-crimson">🎓 Category</p>
  <h1 class="mb-2 font-display text-4xl font-extrabold md:text-5xl">Trivia</h1>
  <p class="mb-8 text-ink-soft">
    {items.length} {items.length === 1 ? "fact" : "facts"}. Movie nerdery for the curious.
  </p>

  {
    items.length === 0 ? (
      <div class="rounded-2xl border-2 border-dashed border-ink/20 bg-cream-dark/40 p-8 text-center">
        <p class="text-ink-soft">No trivia yet. Soon. 🎓</p>
      </div>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2">
        {items.map((entry) => (
          <PostCard post={triviaToSummary(entry)} />
        ))}
      </div>
    )
  }
</BaseLayout>
