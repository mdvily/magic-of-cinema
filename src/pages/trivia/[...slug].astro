---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReactionBar from "../../components/ReactionBar.astro";
import CommentSection from "../../components/CommentSection.astro";

export async function getStaticPaths() {
  const items = await getCollection("trivia");
  return items.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const date = data.publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={data.title}
  description={data.excerpt ?? data.title}
  ogImage={data.movie?.backdropUrl ?? data.movie?.posterUrl}
>
  <article>
    <header class="mb-8 rounded-2xl border-2 border-amber-500/40 bg-amber-500/10 p-5">
      <p class="mb-2 text-xs font-bold uppercase tracking-[0.3em] text-amber-800">
        🎓 Did you know? · {date}
      </p>
      <h1 class="font-display text-3xl font-extrabold leading-tight md:text-4xl">
        {data.title}
      </h1>
      {
        data.movie && (
          <p class="mt-3 text-base text-ink-soft">
            From: <strong>{data.movie.title}</strong>
            {data.movie.year && <span> ({data.movie.year})</span>}
          </p>
        )
      }
    </header>

    {
      data.movie?.posterUrl && (
        <img
          src={data.movie.posterUrl}
          alt={`${data.movie.title} poster`}
          class="mb-8 aspect-[2/3] w-32 rounded-xl object-cover ring-1 ring-ink/10 md:w-40"
        />
      )
    }

    <div class="prose-cinema mx-auto">
      <Content />
    </div>

    {
      data.tags.length > 0 && (
        <div class="mt-12 flex flex-wrap gap-2">
          {data.tags.map((tag) => (
            <span class="rounded-full bg-cream-dark px-3 py-1 text-xs font-medium text-ink-soft">
              #{tag}
            </span>
          ))}
        </div>
      )
    }
  </article>
  <ReactionBar slug={entry.id.replace(/\.md$/, "")} type="trivia" />
  <CommentSection slug={entry.id.replace(/\.md$/, "")} type="trivia" />
</BaseLayout>
