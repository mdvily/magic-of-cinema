---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import GenreFilter from "../components/GenreFilter.astro";
import {
  getReviews,
  getTierLists,
  getTop10s,
  getHotTakes,
  getTrivia,
  reviewToSummary,
  tierListToSummary,
  top10ToSummary,
  hotTakeToSummary,
  triviaToSummary,
} from "../lib/posts.ts";

const [reviews, tierLists, top10s, hotTakes, trivia] = await Promise.all([
  getReviews(),
  getTierLists(),
  getTop10s(),
  getHotTakes(),
  getTrivia(),
]);

const sections: Array<{ heading: string; href: string; summary: ReturnType<typeof reviewToSummary> | null }> = [
  {
    heading: "Latest Review",
    href: "/reviews",
    summary: reviews[0] ? reviewToSummary(reviews[0]) : null,
  },
  {
    heading: "Latest Tier List",
    href: "/tier-lists",
    summary: tierLists[0] ? tierListToSummary(tierLists[0]) : null,
  },
  {
    heading: "Latest Top 10",
    href: "/top-10",
    summary: top10s[0] ? top10ToSummary(top10s[0]) : null,
  },
  {
    heading: "Latest Hot Take",
    href: "/hot-takes",
    summary: hotTakes[0] ? hotTakeToSummary(hotTakes[0]) : null,
  },
  {
    heading: "Latest Trivia",
    href: "/trivia",
    summary: trivia[0] ? triviaToSummary(trivia[0]) : null,
  },
];
---

<BaseLayout>
  <section class="mb-12">
    <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-crimson">
      Now Showing
    </p>
    <h1 class="font-display text-4xl font-extrabold leading-tight md:text-6xl">
      Welcome to <span class="bg-popcorn/60 px-2">Magic of Cinema</span>.
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-ink-soft">
      Movie reviews, ranked lists, hot takes &amp; tier lists by{" "}
      <strong class="text-ink">MovieMan</strong>. Each review is scored across
      Story, Visuals, Characters, Acting &amp; Music — out of 100, no rounding.
    </p>
  </section>

  <GenreFilter />

  <div class="space-y-10">
    {
      sections.map((s) =>
        s.summary ? (
          <section>
            <div class="mb-3 flex items-baseline justify-between">
              <h2 class="font-display text-2xl font-bold">{s.heading}</h2>
              <a href={s.href} class="text-sm font-semibold text-crimson hover:underline">
                See all →
              </a>
            </div>
            <PostCard post={s.summary} />
          </section>
        ) : null,
      )
    }
  </div>
</BaseLayout>
