---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ReviewCard from "../components/ReviewCard.astro";

const allReviews = (await getCollection("reviews"))
  .filter((r) => !r.data.draft)
  .sort(
    (a, b) =>
      b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
  );

const [hero, ...rest] = allReviews;
const recent = rest.slice(0, 5);
---

<BaseLayout>
  <section class="mb-12">
    <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-crimson">
      Now Showing
    </p>
    <h1 class="font-display text-4xl font-extrabold leading-tight md:text-6xl">
      Welcome to <span class="bg-popcorn/60 px-2">Magic of Cinema</span>.
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-ink-soft">
      Movie reviews, ranked lists, hot takes &amp; tier lists by{" "}
      <strong class="text-ink">MovieMan</strong>. Each review is scored across
      Story, Visuals, Characters, Acting &amp; Music — out of 100, no rounding.
    </p>
  </section>

  {
    hero ? (
      <section class="mb-12">
        <h2 class="mb-4 font-display text-2xl font-bold">Latest Review</h2>
        <ReviewCard entry={hero} />
      </section>
    ) : (
      <section class="mb-12 rounded-2xl border-2 border-dashed border-ink/20 bg-cream-dark/40 p-8 text-center">
        <p class="text-ink-soft">No reviews yet. Stay tuned. 🍿</p>
      </section>
    )
  }

  {
    recent.length > 0 && (
      <section>
        <h2 class="mb-4 font-display text-2xl font-bold">More from MovieMan</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {recent.map((entry) => (
            <ReviewCard entry={entry} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
