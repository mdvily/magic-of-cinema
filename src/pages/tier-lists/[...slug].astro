---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TierListView from "../../components/TierListView.astro";
import Giscus from "../../components/Giscus.astro";

export async function getStaticPaths() {
  const lists = await getCollection("tier-lists");
  return lists.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const date = data.publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={data.title}
  description={data.excerpt ?? `${data.title} — a tier list by MovieMan.`}
  ogImage={data.coverImageUrl}
>
  <article>
    <header class="mb-6">
      <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-crimson">
        <span class="rounded bg-marquee/15 px-2 py-0.5 text-marquee">🪜 Tier List</span>
        <span class="ml-2 text-ink-soft">{date}</span>
      </p>
      <h1 class="font-display text-4xl font-extrabold leading-tight md:text-5xl">
        {data.title}
      </h1>
      {data.excerpt && <p class="mt-3 text-lg text-ink-soft">{data.excerpt}</p>}
    </header>

    <div class="prose-cinema mb-8">
      <Content />
    </div>

    <TierListView tiers={data.tiers} />

    {
      data.tags.length > 0 && (
        <div class="mt-12 flex flex-wrap gap-2">
          {data.tags.map((tag) => (
            <span class="rounded-full bg-cream-dark px-3 py-1 text-xs font-medium text-ink-soft">
              #{tag}
            </span>
          ))}
        </div>
      )
    }
  </article>
  <Giscus />
</BaseLayout>
