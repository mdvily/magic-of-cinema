---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReviewCard from "../../components/ReviewCard.astro";

const CATEGORY_LIST = [
  "Reviews",
  "Top 10 Lists",
  "Trivia",
  "Hot Takes",
  "Tier Lists",
] as const;

function slugify(label: string): string {
  return label.toLowerCase().replace(/\s+/g, "-");
}

export async function getStaticPaths() {
  const labels = ["Reviews", "Top 10 Lists", "Trivia", "Hot Takes", "Tier Lists"];
  return labels.map((label) => ({
    params: { category: label.toLowerCase().replace(/\s+/g, "-") },
    props: { label },
  }));
}

const { label } = Astro.props as { label: (typeof CATEGORY_LIST)[number] };

const entries = (await getCollection("reviews"))
  .filter((r) => !r.data.draft && r.data.category === label)
  .sort(
    (a, b) =>
      b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
  );
---

<BaseLayout
  title={label}
  description={`${label} from MovieMan`}
>
  <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-crimson">
    Category
  </p>
  <h1 class="mb-2 font-display text-4xl font-extrabold md:text-5xl">{label}</h1>
  <p class="mb-8 text-ink-soft">
    {entries.length} {entries.length === 1 ? "post" : "posts"} in this category.
  </p>

  {
    entries.length === 0 ? (
      <div class="rounded-2xl border-2 border-dashed border-ink/20 bg-cream-dark/40 p-8 text-center">
        <p class="text-ink-soft">Nothing here yet. Coming soon. 🍿</p>
      </div>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2">
        {entries.map((entry) => (
          <ReviewCard entry={entry} />
        ))}
      </div>
    )
  }
</BaseLayout>
