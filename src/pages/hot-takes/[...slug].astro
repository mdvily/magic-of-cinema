---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const takes = await getCollection("hot-takes");
  return takes.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const date = data.publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={data.title}
  description={data.excerpt ?? data.title}
  ogImage={data.movie?.backdropUrl ?? data.movie?.posterUrl}
>
  <article>
    {/* Dramatic header bar for hot takes */}
    <div class="-mx-4 mb-6 border-y-4 border-crimson bg-crimson/10 px-4 py-3 md:-mx-6 md:px-6">
      <p class="text-xs font-bold uppercase tracking-[0.3em] text-crimson">
        🌶️ Hot Take · {date}
      </p>
    </div>

    <header class="mb-8">
      <h1 class="font-display text-4xl font-extrabold leading-tight md:text-6xl">
        {data.title}
      </h1>
      {
        data.movie && (
          <p class="mt-3 text-lg text-ink-soft">
            About: <strong>{data.movie.title}</strong>
            {data.movie.year && <span> ({data.movie.year})</span>}
          </p>
        )
      }
    </header>

    {
      data.movie?.posterUrl && (
        <img
          src={data.movie.posterUrl}
          alt={`${data.movie.title} poster`}
          class="mb-8 aspect-[2/3] w-40 rounded-xl object-cover ring-1 ring-ink/10 md:w-48"
        />
      )
    }

    <div class="prose-cinema mx-auto">
      <Content />
    </div>

    {
      data.tags.length > 0 && (
        <div class="mt-12 flex flex-wrap gap-2">
          {data.tags.map((tag) => (
            <span class="rounded-full bg-cream-dark px-3 py-1 text-xs font-medium text-ink-soft">
              #{tag}
            </span>
          ))}
        </div>
      )
    }
  </article>
</BaseLayout>
