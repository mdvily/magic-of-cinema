---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReviewCard from "../../components/ReviewCard.astro";

const reviews = (await getCollection("reviews"))
  .filter((r) => !r.data.draft)
  .sort(
    (a, b) =>
      b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
  );
---

<BaseLayout
  title="All Posts"
  description="Every review, list, hot take, and tier list by MovieMan."
>
  <h1 class="mb-2 font-display text-4xl font-extrabold md:text-5xl">
    Every Post
  </h1>
  <p class="mb-8 text-ink-soft">
    {reviews.length} {reviews.length === 1 ? "post" : "posts"} so far.
  </p>

  {
    reviews.length === 0 ? (
      <div class="rounded-2xl border-2 border-dashed border-ink/20 bg-cream-dark/40 p-8 text-center">
        <p class="text-ink-soft">No posts yet. Soon. 🍿</p>
      </div>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2">
        {reviews.map((entry) => (
          <ReviewCard entry={entry} />
        ))}
      </div>
    )
  }
</BaseLayout>
