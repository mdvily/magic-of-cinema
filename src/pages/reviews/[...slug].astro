---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RatingCard from "../../components/RatingCard.astro";
import ReactionBar from "../../components/ReactionBar.astro";
import CommentSection from "../../components/CommentSection.astro";

export async function getStaticPaths() {
  const reviews = await getCollection("reviews");
  return reviews.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const date = data.publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={data.title}
  description={data.excerpt ?? `${data.title} — reviewed by MovieMan.`}
  ogImage={data.movie?.backdropUrl ?? data.movie?.posterUrl}
>
  <article>
    <header class="mb-8">
      <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-crimson">
        <span class="rounded bg-popcorn/40 px-2 py-0.5 text-ink">📝 Review</span>
        <span class="ml-2 text-ink-soft">{date}</span>
      </p>
      <h1 class="font-display text-4xl font-extrabold leading-tight md:text-5xl">
        {data.title}
      </h1>
      {
        data.movie && (
          <p class="mt-3 text-lg text-ink-soft">
            {data.movie.title}
            {data.movie.year && <span> · {data.movie.year}</span>}
            {data.movie.director && <span> · dir. {data.movie.director}</span>}
            {data.movie.runtime && <span> · {data.movie.runtime} min</span>}
          </p>
        )
      }
    </header>

    <div class="mb-10 grid items-start gap-6 md:grid-cols-[auto_1fr]">
      {
        data.movie?.posterUrl && (
          <img
            src={data.movie.posterUrl}
            alt={`${data.movie.title} poster`}
            class="aspect-[2/3] w-48 rounded-xl object-cover ring-1 ring-ink/10 md:w-56"
          />
        )
      }
      {data.rating && <div><RatingCard rating={data.rating} /></div>}
    </div>

    <div class="prose-cinema mx-auto">
      <Content />
    </div>

    {
      data.tags.length > 0 && (
        <div class="mt-12 flex flex-wrap gap-2">
          {data.tags.map((tag) => (
            <span class="rounded-full bg-cream-dark px-3 py-1 text-xs font-medium text-ink-soft">
              #{tag}
            </span>
          ))}
        </div>
      )
    }
  </article>
  <ReactionBar slug={entry.id.replace(/\.md$/, "")} type="reviews" />
  <CommentSection slug={entry.id.replace(/\.md$/, "")} type="reviews" />
</BaseLayout>
