---
import { validateSession } from "../../lib/session";
import { supabase } from "../../lib/supabase";
import BaseLayout from "../../layouts/BaseLayout.astro";

export const prerender = false;

if (!validateSession(Astro.request.headers.get("cookie"))) {
  return Astro.redirect("/moderation/login");
}

const { data: comments, error } = await supabase
  .from("comments")
  .select("id, page_slug, page_type, author_name, content, created_at, status")
  .order("created_at", { ascending: false });

if (error) console.error("moderation fetch error:", error);

const all = comments ?? [];
const pending = all.filter((c) => c.status === "pending");
const approved = all.filter((c) => c.status === "approved");
const rejected = all.filter((c) => c.status === "rejected");

function fmtDate(s: string) {
  return new Date(s).toLocaleString("en-US", {
    month: "short", day: "numeric", year: "numeric",
    hour: "numeric", minute: "2-digit",
  });
}
---

<BaseLayout title="Moderation" description="">
  <div class="mx-auto max-w-2xl">
    <div class="mb-8 flex items-center justify-between">
      <h1 class="font-display text-3xl font-extrabold">🎬 Moderation</h1>
      <form method="POST" action="/api/moderation/logout">
        <button class="text-sm text-ink-soft underline hover:text-ink">Log out</button>
      </form>
    </div>

    <!-- Newsletter -->
    <section class="mb-12">
      <h2 class="mb-1 font-display text-xl font-bold">📧 Newsletter</h2>
      <p id="subscriber-count" class="mb-4 text-sm text-ink-soft">Loading subscriber count...</p>

      <div id="newsletter-draft" class="hidden mb-4 rounded-xl border-2 border-ink/10 bg-white p-4">
        <input
          id="nl-subject"
          type="text"
          class="mb-3 w-full rounded-lg border border-cream-dark px-3 py-2 font-semibold text-ink focus:outline-none focus:ring-2 focus:ring-popcorn"
          placeholder="Subject line"
        />
        <textarea
          id="nl-body"
          rows={16}
          class="w-full resize-y rounded-lg border border-cream-dark px-3 py-2 font-mono text-sm text-ink focus:outline-none focus:ring-2 focus:ring-popcorn"
          placeholder="Markdown body..."
        ></textarea>
        <div class="mt-3 flex gap-2">
          <button id="nl-send-btn" class="rounded-full bg-crimson px-5 py-2 text-sm font-bold text-white hover:bg-red-800">Send to Subscribers</button>
          <button id="nl-discard-btn" class="rounded-full border border-cream-dark px-4 py-2 text-sm text-ink-soft hover:bg-cream-dark">Discard</button>
        </div>
        <p id="nl-send-msg" class="mt-2 hidden text-sm"></p>
      </div>

      <button id="nl-generate-btn" class="rounded-full bg-popcorn/80 px-5 py-2 text-sm font-bold text-ink hover:bg-popcorn">
        Generate This Week's Digest
      </button>

      <div id="nl-history" class="mt-6 space-y-2"></div>
    </section>

    <!-- Fan Requests -->
    <section class="mb-12">
      <h2 class="mb-4 font-display text-xl font-bold">🍿 Fan Requests</h2>
      <div id="mod-requests-list">
        <p class="text-sm text-ink-soft">Loading...</p>
      </div>
    </section>

    <!-- Pending -->
    <section class="mb-10">
      <h2 class="mb-4 font-display text-xl font-bold text-amber-600">
        ⏳ Pending <span class="text-base font-normal text-ink-soft">({pending.length})</span>
      </h2>
      {pending.length === 0 && <p class="text-sm text-ink-soft">All clear.</p>}
      {pending.map((c) => (
        <div class="comment-card mb-3 rounded-lg border border-cream-dark bg-white p-4 shadow-sm" data-id={c.id}>
          <div class="mb-1 flex flex-wrap items-baseline justify-between gap-x-3 gap-y-0.5">
            <span class="font-semibold text-ink">{c.author_name || "Anonymous"}</span>
            <span class="text-xs text-ink-soft">{c.page_type} / {c.page_slug} · {fmtDate(c.created_at)}</span>
          </div>
          <p class="comment-body mb-3 text-sm text-ink-soft">{c.content}</p>
          <div class="flex gap-2">
            <button class="btn-action rounded bg-green-600 px-3 py-1 text-xs font-bold text-white hover:bg-green-700" data-action="approve">Approve</button>
            <button class="btn-action rounded bg-crimson px-3 py-1 text-xs font-bold text-white hover:bg-red-800" data-action="reject">Reject</button>
          </div>
        </div>
      ))}
    </section>

    <!-- Approved -->
    <section class="mb-10">
      <h2 class="mb-4 font-display text-xl font-bold text-green-700">
        ✅ Approved <span class="text-base font-normal text-ink-soft">({approved.length})</span>
      </h2>
      {approved.length === 0 && <p class="text-sm text-ink-soft">No approved comments yet.</p>}
      {approved.map((c) => (
        <div class="comment-card mb-3 rounded-lg border border-cream-dark bg-white p-4 shadow-sm" data-id={c.id}>
          <div class="mb-1 flex flex-wrap items-baseline justify-between gap-x-3 gap-y-0.5">
            <span class="font-semibold text-ink">{c.author_name || "Anonymous"}</span>
            <span class="text-xs text-ink-soft">{c.page_type} / {c.page_slug} · {fmtDate(c.created_at)}</span>
          </div>
          <p class="comment-body mb-3 text-sm text-ink-soft">{c.content}</p>
          <textarea
            class="edit-input hidden mb-3 w-full resize-none rounded border border-cream-dark p-2 text-sm text-ink focus:outline-none focus:ring-2 focus:ring-popcorn"
            rows={3}
          >{c.content}</textarea>
          <div class="flex gap-2">
            <button class="btn-edit rounded border border-cream-dark px-3 py-1 text-xs font-medium text-ink hover:bg-cream-dark">Edit</button>
            <button class="btn-save hidden rounded bg-popcorn px-3 py-1 text-xs font-bold text-ink hover:bg-popcorn-deep">Save</button>
            <button class="btn-cancel hidden rounded border border-cream-dark px-3 py-1 text-xs text-ink-soft hover:bg-cream-dark">Cancel</button>
            <button class="btn-action rounded bg-crimson px-3 py-1 text-xs font-bold text-white hover:bg-red-800" data-action="reject">Delete</button>
          </div>
        </div>
      ))}
    </section>

    <!-- Rejected -->
    <section class="mb-10">
      <h2 class="mb-4 font-display text-xl font-bold text-crimson">
        ❌ Rejected <span class="text-base font-normal text-ink-soft">({rejected.length})</span>
      </h2>
      {rejected.length === 0 && <p class="text-sm text-ink-soft">Nothing here.</p>}
      {rejected.map((c) => (
        <div class="comment-card mb-3 rounded-lg border border-cream-dark bg-white p-4 shadow-sm opacity-60" data-id={c.id}>
          <div class="mb-1 flex flex-wrap items-baseline justify-between gap-x-3 gap-y-0.5">
            <span class="font-semibold text-ink">{c.author_name || "Anonymous"}</span>
            <span class="text-xs text-ink-soft">{c.page_type} / {c.page_slug} · {fmtDate(c.created_at)}</span>
          </div>
          <p class="comment-body mb-3 text-sm line-through text-ink-soft">{c.content}</p>
          <div class="flex gap-2">
            <button class="btn-action rounded bg-green-600 px-3 py-1 text-xs font-bold text-white hover:bg-green-700" data-action="restore">Restore</button>
          </div>
        </div>
      ))}
    </section>
  </div>
</BaseLayout>

<script>
  /* ---- Newsletter ---- */
  let currentDraftId: string | null = null;

  const subCount = document.getElementById("subscriber-count")!;
  const draftEl = document.getElementById("newsletter-draft")!;
  const nlSubject = document.getElementById("nl-subject") as HTMLInputElement;
  const nlBody = document.getElementById("nl-body") as HTMLTextAreaElement;
  const nlGenerateBtn = document.getElementById("nl-generate-btn") as HTMLButtonElement;
  const nlSendBtn = document.getElementById("nl-send-btn") as HTMLButtonElement;
  const nlDiscardBtn = document.getElementById("nl-discard-btn") as HTMLButtonElement;
  const nlSendMsg = document.getElementById("nl-send-msg")!;
  const nlHistory = document.getElementById("nl-history")!;

  async function loadNewsletterData() {
    const [{ data: subs }, { data: newsletters }] = await Promise.all([
      fetch("/api/newsletter/subscribers").then((r) => r.json()),
      fetch("/api/newsletter/history").then((r) => r.json()),
    ]);

    subCount.textContent = `${subs?.count ?? 0} active subscriber${subs?.count === 1 ? "" : "s"}`;

    // Show latest draft if exists
    const draft = (newsletters ?? []).find((n: { status: string }) => n.status === "draft");
    if (draft) {
      showDraft(draft);
    }

    // Show sent history
    const sent = (newsletters ?? []).filter((n: { status: string }) => n.status === "sent");
    if (sent.length > 0) {
      nlHistory.innerHTML = `<p class="text-xs font-semibold uppercase tracking-widest text-ink-soft mb-2">Sent</p>` +
        sent.map((n: { id: string; subject: string; sent_at: string }) => `
          <div class="rounded-lg border border-cream-dark bg-white px-3 py-2 text-sm">
            <span class="font-medium">${n.subject}</span>
            <span class="ml-2 text-xs text-ink-soft">${new Date(n.sent_at).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
          </div>
        `).join("");
    }
  }

  function showDraft(draft: { id: string; subject: string; body_md: string }) {
    currentDraftId = draft.id;
    nlSubject.value = draft.subject;
    nlBody.value = draft.body_md;
    draftEl.classList.remove("hidden");
    nlGenerateBtn.textContent = "Regenerate Digest";
  }

  nlGenerateBtn.addEventListener("click", async () => {
    nlGenerateBtn.disabled = true;
    nlGenerateBtn.textContent = "Generating...";

    const res = await fetch("/api/newsletter/generate", { method: "POST" });
    const data = await res.json();

    if (res.ok) {
      showDraft(data.newsletter);
      nlGenerateBtn.textContent = "Regenerate Digest";
    } else {
      alert("Generate failed: " + (data.error ?? "unknown error"));
      nlGenerateBtn.textContent = "Generate This Week's Digest";
    }
    nlGenerateBtn.disabled = false;
  });

  nlSendBtn.addEventListener("click", async () => {
    if (!currentDraftId) return;
    if (!confirm("Send this newsletter to all active subscribers?")) return;

    nlSendBtn.disabled = true;
    nlSendBtn.textContent = "Sending...";
    nlSendMsg.classList.add("hidden");

    const res = await fetch("/api/newsletter/send", {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify({
        newsletterId: currentDraftId,
        subject: nlSubject.value.trim(),
        body_md: nlBody.value.trim(),
      }),
    });
    const data = await res.json();

    if (res.ok) {
      nlSendMsg.textContent = `✓ Sent to ${data.sent} subscriber${data.sent === 1 ? "" : "s"}.`;
      nlSendMsg.className = "mt-2 text-sm text-green-700";
      nlSendMsg.classList.remove("hidden");
      draftEl.classList.add("hidden");
      currentDraftId = null;
      nlGenerateBtn.textContent = "Generate This Week's Digest";
      loadNewsletterData();
    } else {
      nlSendMsg.textContent = "Send failed: " + (data.error ?? "unknown error");
      nlSendMsg.className = "mt-2 text-sm text-crimson";
      nlSendMsg.classList.remove("hidden");
      nlSendBtn.disabled = false;
      nlSendBtn.textContent = "Send to Subscribers";
    }
  });

  nlDiscardBtn.addEventListener("click", async () => {
    if (!currentDraftId || !confirm("Discard this draft?")) return;
    await fetch("/api/newsletter/delete-draft", {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify({ newsletterId: currentDraftId }),
    });
    draftEl.classList.add("hidden");
    currentDraftId = null;
    nlGenerateBtn.textContent = "Generate This Week's Digest";
  });

  loadNewsletterData();

  /* ---- Fan Requests ---- */
  type FanRequest = {
    id: string;
    tmdbId: number;
    title: string;
    year?: number;
    posterUrl?: string;
    director?: string;
    status: string;
    voteTotal: number;
  };

  async function loadModRequests() {
    const res = await fetch("/api/requests/list");
    const { requests }: { requests: FanRequest[] } = await res.json();
    const el = document.getElementById("mod-requests-list")!;

    if (!requests?.length) {
      el.innerHTML = `<p class="text-sm text-ink-soft">No requests yet.</p>`;
      return;
    }

    el.innerHTML = requests.map((r) => {
      const isPicked = r.status === "picked";
      const isReviewed = r.status === "reviewed";
      return `
        <div class="request-mod-card mb-2 flex items-center gap-3 rounded-lg border border-cream-dark bg-white p-3 shadow-sm" data-id="${r.id}">
          ${r.posterUrl ? `<img src="${r.posterUrl}" class="w-10 shrink-0 rounded object-cover" alt="" />` : ""}
          <div class="flex-1 min-w-0">
            <p class="font-semibold truncate">${r.title}${r.year ? ` (${r.year})` : ""}</p>
            <p class="text-xs text-ink-soft">${r.director ?? ""} · <span class="font-mono font-bold">${r.voteTotal > 0 ? "+" : ""}${r.voteTotal} votes</span></p>
          </div>
          <div class="flex shrink-0 gap-1.5">
            ${isReviewed
              ? `<span class="rounded-full bg-crimson/10 px-2.5 py-1 text-xs font-bold text-crimson">✓ Reviewed</span>`
              : isPicked
              ? `
                  <button class="req-status-btn rounded-full bg-popcorn px-2.5 py-1 text-xs font-bold text-ink" data-status="reviewed">Mark Reviewed</button>
                  <button class="req-status-btn rounded-full border border-cream-dark px-2.5 py-1 text-xs font-medium text-ink-soft" data-status="active">Unpick</button>
                `
              : `
                  <button class="req-status-btn rounded-full bg-popcorn/80 px-2.5 py-1 text-xs font-bold text-ink hover:bg-popcorn" data-status="picked">Pick</button>
                `
            }
            <button class="req-delete-btn rounded-full border border-crimson/30 px-2.5 py-1 text-xs font-medium text-crimson hover:bg-crimson hover:text-white">Remove</button>
          </div>
        </div>
      `;
    }).join("");

    document.querySelectorAll<HTMLButtonElement>(".req-status-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const card = btn.closest<HTMLElement>(".request-mod-card")!;
        const id = card.dataset.id!;
        const status = btn.dataset.status!;
        btn.disabled = true;
        btn.textContent = "…";

        const res = await fetch("/api/requests/status", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ requestId: id, status }),
        });

        if (res.ok) {
          loadModRequests();
        } else {
          btn.disabled = false;
          btn.textContent = "Error";
        }
      });
    });

    document.querySelectorAll<HTMLButtonElement>(".req-delete-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const card = btn.closest<HTMLElement>(".request-mod-card")!;
        const id = card.dataset.id!;
        const title = card.querySelector("p.font-semibold")?.textContent?.trim() ?? "this request";
        if (!confirm(`Remove "${title}"? This cannot be undone.`)) return;

        btn.disabled = true;
        btn.textContent = "…";

        const res = await fetch("/api/requests/delete", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ requestId: id }),
        });

        if (res.ok) {
          card.remove();
        } else {
          btn.disabled = false;
          btn.textContent = "Remove";
          alert("Delete failed. Try again.");
        }
      });
    });
  }

  loadModRequests();

  // Approve / reject / restore
  document.querySelectorAll<HTMLButtonElement>(".btn-action").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const card = btn.closest<HTMLElement>(".comment-card")!;
      const id = card.dataset.id!;
      const action = btn.dataset.action!;
      const originalText = btn.textContent!;
      btn.disabled = true;
      btn.textContent = "…";

      const res = await fetch("/api/moderation/comment", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ id, action }),
      });

      if (res.ok) {
        card.remove();
      } else {
        btn.disabled = false;
        btn.textContent = originalText;
        alert("Something went wrong. Try again.");
      }
    });
  });

  // Inline edit for approved comments
  document.querySelectorAll<HTMLElement>(".comment-card").forEach((card) => {
    const editBtn = card.querySelector<HTMLButtonElement>(".btn-edit");
    const saveBtn = card.querySelector<HTMLButtonElement>(".btn-save");
    const cancelBtn = card.querySelector<HTMLButtonElement>(".btn-cancel");
    const bodyEl = card.querySelector<HTMLElement>(".comment-body");
    const textarea = card.querySelector<HTMLTextAreaElement>(".edit-input");
    if (!editBtn || !saveBtn || !cancelBtn || !bodyEl || !textarea) return;

    const enterEdit = () => {
      textarea.value = bodyEl.textContent?.trim() ?? "";
      bodyEl.classList.add("hidden");
      textarea.classList.remove("hidden");
      editBtn.classList.add("hidden");
      saveBtn.classList.remove("hidden");
      cancelBtn.classList.remove("hidden");
      textarea.focus();
    };

    const exitEdit = () => {
      bodyEl.classList.remove("hidden");
      textarea.classList.add("hidden");
      editBtn.classList.remove("hidden");
      saveBtn.classList.add("hidden");
      cancelBtn.classList.add("hidden");
    };

    editBtn.addEventListener("click", enterEdit);
    cancelBtn.addEventListener("click", exitEdit);

    saveBtn.addEventListener("click", async () => {
      const id = card.dataset.id!;
      const body = textarea.value.trim();
      if (!body) return;
      saveBtn.disabled = true;
      saveBtn.textContent = "…";

      const res = await fetch("/api/moderation/comment", {
        method: "PATCH",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ id, content: body }),
      });

      if (res.ok) {
        bodyEl.textContent = body;
        exitEdit();
      } else {
        alert("Save failed. Try again.");
      }
      saveBtn.disabled = false;
      saveBtn.textContent = "Save";
    });
  });
</script>
