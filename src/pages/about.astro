---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const entry = await getEntry("about", "about");
const data = entry?.data;
const Content = entry ? (await render(entry)).Content : null;
---

<BaseLayout
  title={data?.title ?? "About MovieMan"}
  description="About MovieMan, the critic behind Magic of Cinema."
>
  <article>
    <header class="mb-8 flex flex-col items-start gap-6 md:flex-row md:items-center">
      {
        data?.avatarUrl && (
          <img
            src={data.avatarUrl}
            alt="MovieMan avatar"
            class="h-32 w-32 rounded-full object-cover ring-4 ring-popcorn"
          />
        )
      }
      <div>
        <h1 class="font-display text-4xl font-extrabold md:text-5xl">
          {data?.title ?? "About MovieMan"}
        </h1>
        {
          data?.updatedDate && (
            <p class="mt-1 text-sm text-ink-soft">
              Last updated{" "}
              {data.updatedDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </p>
          )
        }
      </div>
    </header>

    <div class="prose-cinema">
      {Content ? <Content /> : <p class="text-ink-soft">About page coming soon.</p>}
    </div>
  </article>
</BaseLayout>
