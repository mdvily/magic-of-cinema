---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About MovieMan" description="About MovieMan, the critic behind Magic of Cinema.">
  <h1 class="mb-4 font-display text-4xl font-extrabold md:text-5xl">
    About MovieMan
  </h1>
  <div class="prose-cinema">
    <p>
      MovieMan is a teenage critic who watches a lot of movies and has a lot of
      opinions about them. Welcome to <strong>Magic of Cinema</strong> — the
      home for those opinions.
    </p>
    <p>
      Every review here is scored across five categories — Story, Visuals,
      Characters, Acting, and Music — each on a 0–20 popcorn scale. Add them up
      and you get the overall MovieMan Verdict, out of 100. No rounding, no
      half-popcorn cheating.
    </p>
    <p>
      Want to know how the rating system works in detail? <a href="/rating-system">Here you go.</a>
    </p>
    <h2>Get in touch</h2>
    <p>
      If you want to suggest a movie, drop a comment on any review. (Comments
      are GitHub-backed — you'll need a free GitHub account.)
    </p>
  </div>
</BaseLayout>
